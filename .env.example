# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/banking_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=banking_db
DB_USER=postgres
DB_PASSWORD=password

# Data Generation
NUM_CUSTOMERS=25000
NUM_ACCOUNTS=40000
NUM_TRANSACTIONS=500000
NUM_GL_ENTRIES=500000
DATA_MONTHS=12
SEED=42

# API
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=false

# Logging
LOG_LEVEL=INFO
